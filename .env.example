# ============================================================
# DAGDAG PUHUNAN — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ─── SUPABASE (Database & Auth) ──────────────────────────────
# Found in: supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose to frontend, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── JWT (Express API Server) ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── EXPRESS SERVER ───────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001

# ─── CORS ─────────────────────────────────────────────────────
# In production, set to your Vercel domain
CORS_ORIGIN=http://localhost:5173

# ─── EMAIL (Resend) ───────────────────────────────────────────
# Get free API key at resend.com (3,000 emails/month free)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@lgusanpedro.ph
EMAIL_FROM_NAME=DAGDAG PUHUNAN — LGU San Pedro

# ─── DATABASE (Direct PostgreSQL, optional) ───────────────────
# Only needed if connecting directly without Supabase SDK
DATABASE_URL=postgresql://postgres:password@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── RATE LIMITING ────────────────────────────────────────────
# Max login attempts per IP per 15 minutes
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=900000

# ─── SESSION ──────────────────────────────────────────────────
SESSION_SECRET=another-long-random-string-for-sessions

# ─── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── FRONTEND ─────────────────────────────────────────────────
VITE_APP_NAME=DAGDAG PUHUNAN, ZERO INTEREST
VITE_APP_ENV=development

# ─── SECURITY ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12
